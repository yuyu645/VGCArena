# Copia este archivo a .env y rellena los valores.

# Clave para firmar los JWT. OBLIGATORIA en producción.
# Genera una aleatoria, p. ej.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000

# Entorno: development | production
NODE_ENV=development

# Cadena de conexión a Postgres (opcional). Si se define, la app usa Postgres
# en vez del archivo JSON local — necesario para persistencia real en hosts
# gratuitos sin disco propio (p. ej. Render free + Neon/Supabase).
# Formato típico: postgresql://usuario:password@host/basededatos?sslmode=require
DATABASE_URL=

# Ruta absoluta al archivo de base de datos JSON (opcional, se ignora si
# DATABASE_URL está definida). Solo útil en producción con disco persistente
# propio (p. ej. Render con plan de pago + disco): debe apuntar fuera de /data
# para no perder datos en cada redeploy ni pisar los JSON estáticos
# versionados (regulations, tags, items, etc.).
DB_FILE=
