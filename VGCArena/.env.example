# Copia este archivo a .env y rellena los valores.

# Clave para firmar los JWT. OBLIGATORIA en producción.
# Genera una aleatoria, p. ej.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000

# Entorno: development | production
NODE_ENV=development

# Ruta absoluta al archivo de base de datos JSON (opcional).
# Solo necesario en producción con disco persistente (p. ej. Render): debe
# apuntar fuera de /data para no perder datos en cada redeploy ni pisar los
# JSON estáticos versionados (regulations, tags, items, etc.).
DB_FILE=
